{"version":"NotebookV1","origId":666239388041108,"name":"antidepressivos_limpos_bi","language":"python","commands":[{"version":"CommandV1","origId":5483154251101039,"guid":"ea801c94-7054-465b-994d-54e2d4095b4f","subtype":"command","commandType":"auto","position":1.0,"command":"from pyspark.sql.functions import col, upper, trim, round, when\n\ndados_brutos = spark.table(\"workspace.default.antidepressivos_brasil_unificado\")\n\ntabela_limpa = (\n    dados_brutos\n    .select(\n        col(\"id_linha\").cast(\"int\").alias(\"id_linha\"),\n        col(\"ano\").cast(\"int\").alias(\"ano_referencia\"),\n        upper(trim(col(\"regiao\"))).alias(\"regiao_nome\"),\n        upper(trim(col(\"estado\"))).alias(\"estado_nome\"),\n        when(col(\"uf\").isNull(), \"BR\")\n        .otherwise(upper(col(\"uf\")))\n        .alias(\"uf_sigla\"),\n        round(col(\"unidades_vendidas_est\"), 0).cast(\"long\").alias(\"vendas_unidades\"),\n        round(col(\"prev_depressao_regiao_pct\"), 2).alias(\"percentual_prevalencia_depressao\"),\n        round(col(\"psiquiatras_por_100mil\"), 2).alias(\"densidade_psiquiatras_por_100mil\"),\n        round((col(\"unidades_vendidas_est\") / col(\"populacao_2022\")) * 100000, 2)\n        .alias(\"kpi_vendas_por_100mil_hab\")\n    )\n    .filter(col(\"ano_referencia\") >= 2019)\n)\n\n(\n    tabela_limpa.write\n    .format(\"delta\")\n    .mode(\"overwrite\")\n    .saveAsTable(\"workspace.default.antidepressivos_limpos_bi\")\n)\n\nprint(f\"Processamento concluído!\")\nprint(f\"Registros brutos: {dados_brutos.count()}\")\nprint(f\"Registros limpos: {tabela_limpa.count()}\")\ndisplay(tabela_limpa.limit(15))","commandVersion":9,"state":"finished","results":{"type":"listResults","data":[{"type":"ansi","data":"Processamento concluído!\nRegistros brutos: 560\nRegistros limpos: 480\n","name":"stdout","arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[],"metadata":{}},{"type":"table","data":[[3,2019,"SUL","RIO GRANDE DO SUL","RS",4507928,15.2,4.2,41430.31],[4,2020,"SUL","RIO GRANDE DO SUL","RS",5184117,15.2,4.2,47644.85],[5,2021,"SUL","RIO GRANDE DO SUL","RS",5806211,15.2,4.2,53362.24],[6,2022,"SUL","RIO GRANDE DO SUL","RS",5632025,15.2,4.2,51761.37],[7,2023,"SUL","RIO GRANDE DO SUL","RS",6195228,15.2,4.2,56937.51],[8,2024,"SUL","RIO GRANDE DO SUL","RS",6443037,15.2,4.2,59215.01],[11,2019,"SUL","SANTA CATARINA","SC",3152681,15.2,4.2,41430.31],[12,2020,"SUL","SANTA CATARINA","SC",3688637,15.2,4.2,48473.46],[13,2021,"SUL","SANTA CATARINA","SC",4168160,15.2,4.2,54775.01],[14,2022,"SUL","SANTA CATARINA","SC",4084797,15.2,4.2,53679.52],[15,2023,"SUL","SANTA CATARINA","SC",4534125,15.2,4.2,59584.27],[16,2024,"SUL","SANTA CATARINA","SC",4715490,15.2,4.2,61967.64],[19,2019,"SUL","PARANÁ","PR",4771462,15.2,4.2,41430.31],[20,2020,"SUL","PARANÁ","PR",5487181,15.2,4.2,47644.85],[21,2021,"SUL","PARANÁ","PR",6090771,15.2,4.2,52885.78]],"arguments":{},"addedWidgets":{},"removedWidgets":[],"schema":[{"name":"id_linha","type":"\"integer\"","metadata":"{}"},{"name":"ano_referencia","type":"\"integer\"","metadata":"{}"},{"name":"regiao_nome","type":"\"string\"","metadata":"{}"},{"name":"estado_nome","type":"\"string\"","metadata":"{}"},{"name":"uf_sigla","type":"\"string\"","metadata":"{}"},{"name":"vendas_unidades","type":"\"long\"","metadata":"{}"},{"name":"percentual_prevalencia_depressao","type":"\"double\"","metadata":"{}"},{"name":"densidade_psiquiatras_por_100mil","type":"\"double\"","metadata":"{}"},{"name":"kpi_vendas_por_100mil_hab","type":"\"double\"","metadata":"{}"}],"overflow":false,"aggData":[],"aggSchema":[],"aggOverflow":false,"aggSeriesLimitReached":false,"aggError":"","aggType":"","plotOptions":null,"isJsonSchema":true,"dbfsResultPath":null,"datasetInfos":[],"columnCustomDisplayInfos":{},"metadata":{}}],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"dados_brutos","typeStr":"pyspark.sql.connect.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"id_linha","